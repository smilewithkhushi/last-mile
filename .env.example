# ── LLM ──────────────────────────────────────────────────────────────────────
# NVIDIA NIM (recommended — use a 49B+ model for reliable structured output)
LLM_PROVIDER=openai
LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
LLM_ENDPOINT=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=nvapi-...

# Alternatives:
# OpenAI:    LLM_PROVIDER=openai  LLM_MODEL=gpt-4o-mini  OPENAI_API_KEY=sk-...
# Anthropic: LLM_PROVIDER=anthropic  LLM_MODEL=claude-haiku-4-5-20251001  ANTHROPIC_API_KEY=...

# ── Embeddings ────────────────────────────────────────────────────────────────
# fastembed runs locally — no API key or network needed.
# NVIDIA NIM embedding models reject the request shape Cognee sends, so keep this.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# ── Cognee Cloud ──────────────────────────────────────────────────────────────
# Agent runs (conflict resolutions, risk assessments, feedback corrections) are
# mirrored to Cognee Cloud so they appear in the Sessions dashboard.
COGNEE_API_KEY=your-cognee-cloud-api-key
COGNEE_BASE_URL=https://your-tenant.aws.cognee.ai

# ── Voice transcription ───────────────────────────────────────────────────────
# Whisper runs via OpenAI's API — separate from the LLM provider above.
# Leave blank to disable voice notes (drivers can still use quick tags + text).
WHISPER_API_KEY=sk-...

# ── App config ────────────────────────────────────────────────────────────────
# Cost per failed delivery attempt (USD) — used in ops dashboard
FAILED_DELIVERY_COST=15.0

# How many days before a note is considered stale
STALE_NOTE_DAYS=30
