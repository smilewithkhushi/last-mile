# LLM Provider — "openai", "anthropic", or "custom" (e.g. NVIDIA NIM / build.nvidia.com)
LLM_PROVIDER=custom
# For NVIDIA NIM, use the "openai/" LiteLLM prefix + a chat model slug from
# https://build.nvidia.com/models. Not every model responds reliably through
# this pipeline — meta/llama-3.1-8b-instruct is fast and stable; some larger
# models (e.g. meta/llama-3.3-70b-instruct) have hung for minutes on some keys.
LLM_MODEL=openai/meta/llama-3.1-8b-instruct
LLM_ENDPOINT=https://integrate.api.nvidia.com/v1
LLM_API_KEY=nvapi-...

# Embeddings run locally via fastembed rather than NVIDIA NIM — NVIDIA's
# hosted embedding models (nv-embedqa-*, nv-embed-v1, bge-m3) all reject the
# exact request shape Cognee's embedding client sends (missing input_type, or
# rejecting the dimensions field), so they fail through this pipeline even
# though they work via a raw curl call. fastembed needs no API key/network.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# If you'd rather use OpenAI or Anthropic directly instead of NVIDIA NIM,
# set LLM_PROVIDER=openai or LLM_PROVIDER=anthropic and fill in the matching key.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=

# Cognee (leave blank to use local/default; set if using Cognee Cloud)
COGNEE_API_KEY=

# Voice-note transcription — "openai" (default) or "whisper-api" (whisper-api.com,
# a third-party async transcription service: submits a file, then polls for a result).
# TRANSCRIPTION_PROVIDER=openai
# TRANSCRIPTION_MODEL=whisper-1
# WHISPER_API_KEY=sk-...          # OpenAI key (if provider=openai) or whisper-api.com key (if provider=whisper-api)
# WHISPER_API_BASE_URL=https://api.whisper-api.com
# WHISPER_API_POLL_INTERVAL=2
# WHISPER_API_POLL_TIMEOUT=60

# Cost per failed delivery attempt (USD) — used in ops dashboard
FAILED_DELIVERY_COST=15.0

# How many days before a note is considered stale
STALE_NOTE_DAYS=30

# Landmark-based addressing (villages/areas with no formal address — see
# backend/landmarks.py). Runs its own small local embedding model, independent
# of EMBEDDING_PROVIDER above. Defaults are calibrated against paraphrase and
# Hindi/English mixed-language test pairs; only override if you've re-tuned.
# LANDMARK_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# LANDMARK_AUTO_MATCH_THRESHOLD=0.65
# LANDMARK_SUGGEST_THRESHOLD=0.45

# ── Deployment-only (leave unset for local dev — sensible defaults apply) ──

# Streamlit frontend: base URL of the deployed backend API (e.g. on Railway,
# the backend service's public domain). Defaults to http://localhost:8000.
# API_BASE=https://your-backend-service.up.railway.app

# Backend: override where the SQLite db and Cognee's local graph/vector
# storage live — point these at a mounted volume path (e.g. /data) on
# platforms like Railway so data survives redeploys.
# SQLITE_DB_PATH=/data/last_mile.db
# DATA_ROOT_DIRECTORY=/data/.data_storage
# SYSTEM_ROOT_DIRECTORY=/data/.cognee_system
# CACHE_ROOT_DIRECTORY=/data/.cognee_cache
